      "source": [
        "# gerar um código que organize arquivos bagunçados em pastas automaticamente, baseando-se apenas na extensão do arquivo(ex .pdf, .jpg)\n",
        "\n",
        "import os\n",
        "import shutil\n",
        "\n",
        "def organizar_arquivos_por_extensao(diretorio_origem):\n",
        "    \"\"\"\n",
        "    Organiza arquivos em um diretório, movendo-os para subpastas\n",
        "    criadas com base em suas extensões.\n",
        "    \"\"\"\n",
        "    if not os.path.isdir(diretorio_origem):\n",
        "        print(f\"Erro: O diretório '{diretorio_origem}' não existe.\")\n",
        "        return\n",
        "\n",
        "    print(f\"Organizando arquivos em: {diretorio_origem}\")\n",
        "\n",
        "    for nome_arquivo in os.listdir(diretorio_origem):\n",
        "        caminho_completo_origem = os.path.join(diretorio_origem, nome_arquivo)\n",
        "\n",
        "        # Ignora diretórios e links simbólicos para processar apenas arquivos\n",
        "        if os.path.isfile(caminho_completo_origem):\n",
        "            # Separa o nome do arquivo da extensão\n",
        "            nome_base, extensao = os.path.splitext(nome_arquivo)\n",
        "\n",
        "            # Remove o ponto da extensão e a torna minúscula (ex: '.pdf' -> 'pdf')\n",
        "            extensao = extensao[1:].lower()\n",
        "\n",
        "            if extensao:\n",
        "                # Cria o nome da pasta (ex: 'PDFs', 'JPEGs')\n",
        "                nome_pasta = extensao.upper() + 's' # Adiciona 's' para pluralizar\n",
        "\n",
        "                # Mapeamento para nomes de pastas mais amigáveis para certas extensões\n",
        "                mapeamento_pastas = {\n",
        "                    'pdf': 'PDFs',\n",
        "                    'doc': 'Documentos',\n",
        "                    'docx': 'Documentos',\n",
        "                    'txt': 'Documentos',\n",
        "                    'xls': 'Planilhas',\n",
        "                    'xlsx': 'Planilhas',\n",
        "                    'ppt': 'Apresentações',\n",
        "                    'pptx': 'Apresentações',\n",
        "                    'jpg': 'Imagens',\n",
        "                    'jpeg': 'Imagens',\n",
        "                    'png': 'Imagens',\n",
        "                    'gif': 'Imagens',\n",
        "                    'mp3': 'Áudios',\n",
        "                    'wav': 'Áudios',\n",
        "                    'mp4': 'Vídeos',\n",
        "                    'avi': 'Vídeos',\n",
        "                    'zip': 'Compactados',\n",
        "                    'rar': 'Compactados',\n",
        "                    'exe': 'Executáveis',\n",
        "                    'py': 'Scripts_Python',\n",
        "                    'js': 'Scripts_Web',\n",
        "                    'html': 'Scripts_Web',\n",
        "                    'css': 'Scripts_Web'\n",
        "                }\n",
        "                nome_pasta = mapeamento_pastas.get(extensao, nome_pasta) # Usa o mapeamento se existir, senão o gerado\n",
        "\n",
        "                caminho_pasta_destino = os.path.join(diretorio_origem, nome_pasta)\n",
        "\n",
        "                # Cria a pasta de destino se ela não existir\n",
        "                if not os.path.exists(caminho_pasta_destino):\n",
        "                    os.makedirs(caminho_pasta_destino)\n",
        "                    print(f\"Pasta criada: {caminho_pasta_destino}\")\n",
        "\n",
        "                caminho_completo_destino = os.path.join(caminho_pasta_destino, nome_arquivo)\n",
        "\n",
        "                try:\n",
        "                    shutil.move(caminho_completo_origem, caminho_completo_destino)\n",
        "                    print(f\"Movido: '{nome_arquivo}' para '{nome_pasta}/'\")\n",
        "                except shutil.Error as e:\n",
        "                    print(f\"Erro ao mover '{nome_arquivo}': {e}\")\n",
        "            else:\n",
        "                # Caso o arquivo não tenha extensão (ou seja um diretório, mas já filtramos diretórios)\n",
        "                # Podemos criar uma pasta para 'Sem_Extensao' ou 'Outros'\n",
        "                pasta_outros = os.path.join(diretorio_origem, 'Outros')\n",
        "                if not os.path.exists(pasta_outros):\n",
        "                    os.makedirs(pasta_outros)\n",
        "                    print(f\"Pasta criada: {pasta_outros}\")\n",
        "                try:\n",
        "                    shutil.move(caminho_completo_origem, os.path.join(pasta_outros, nome_arquivo))\n",
        "                    print(f\"Movido: '{nome_arquivo}' para 'Outros/' (sem extensão ou não reconhecido).\")\n",
        "                except shutil.Error as e:\n",
        "                    print(f\"Erro ao mover '{nome_arquivo}': {e}\")\n",
        "\n",
        "    print(\"Organização concluída!\")\n",
        "\n",
        "# --- Como usar ---\n",
        "# Você pode substituir '.' pelo caminho do diretório que deseja organizar.\n",
        "# Por exemplo: diretorio_a_organizar = '/caminho/para/seus/arquivos'\n",
        "# Atenção: Este script MOVERÁ seus arquivos. Recomenda-se testar em uma pasta de teste primeiro.\n",
        "# diretorio_a_organizar = '.' # O diretório atual onde o script está sendo executado\n",
